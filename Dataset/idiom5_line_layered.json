{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "background": "transparent",
  "data": {"url": "malaysia_dengue_weather_derived.csv"},
  "encoding": {
    "x": {"field": "Year", "type": "ordinal", "axis": {"title": "Observation Period", "labelFont": "sans-serif", "titleFont": "Times New Roman"}}
  },
  "layer": [
    {
      "mark": {"type": "line", "color": "#26A69A", "strokeWidth": 2.5, "point": true},
      "encoding": {
        "y": {
          "field": "Average_Humidity",
          "type": "quantitative",
          "aggregate": "mean",
          "scale": {"zero": false},
          "axis": {"title": "Mean Humidity (%)", "titleColor": "#26A69A", "labelFont": "sans-serif", "titleFont": "Times New Roman"}
        }
      }
    },
    {
      "mark": {"type": "line", "color": "#FB8C00", "strokeWidth": 2.5, "point": {"color": "#FB8C00"}},
      "encoding": {
        "y": {
          "field": "Average_Temperature",
          "type": "quantitative",
          "aggregate": "mean",
          "scale": {"zero": false, "domain": [25, 29]},
          "axis": {"title": "Mean Temperature (°C)", "titleColor": "#FB8C00", "labelFont": "sans-serif", "titleFont": "Times New Roman"}
        }
      }
    }
  ]
}