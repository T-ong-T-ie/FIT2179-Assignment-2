{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 220,
  "background": "transparent",
  "data": {"url": "malaysia_dengue_weather_derived.csv"},
  "layer": [
    {
      "mark": {"type": "point", "color": "#FB8C00", "opacity": 0.6, "filled": true},
      "encoding": {
        "x": {"field": "Average_UV_Index", "type": "quantitative", "axis": {"title": "Solar UV Exposure Index", "labelFont": "sans-serif", "titleFont": "Times New Roman"}},
        "y": {"field": "Dengue_Cases", "type": "quantitative", "axis": {"title": "Dengue Registry Counts", "labelFont": "sans-serif", "titleFont": "Times New Roman"}}
      }
    },
    {
      "mark": {"type": "line", "color": "#E53935", "strokeWidth": 2},
      "transform": [
        {"regression": "Dengue_Cases", "on": "Average_UV_Index"}
      ],
      "encoding": {
        "x": {"field": "Average_UV_Index", "type": "quantitative"},
        "y": {"field": "Dengue_Cases", "type": "quantitative"}
      }
    }
  ]
}