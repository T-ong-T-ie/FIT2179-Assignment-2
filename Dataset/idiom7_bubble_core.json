{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 340,
  "background": "transparent",
  "data": {"url": "malaysia_dengue_weather_derived.csv"},
  "mark": {"type": "point", "filled": true, "opacity": 0.75},
  "encoding": {
    "x": {
      "field": "Average_Temperature",
      "type": "quantitative",
      "scale": {"zero": false},
      "axis": {"title": "Thermal Index Context (°C)", "labelFont": "sans-serif", "titleFont": "Times New Roman", "grid": true}
    },
    "y": {
      "field": "Average_Humidity",
      "type": "quantitative",
      "scale": {"zero": false},
      "axis": {"title": "Moisture Coefficient Field (%)", "labelFont": "sans-serif", "titleFont": "Times New Roman", "grid": true}
    },
    "size": {
      "field": "Dengue_Cases",
      "type": "quantitative",
      "title": "Outbreak Geometry Scale",
      "scale": {"range": [60, 1300]},
      "legend": {"labelFont": "sans-serif", "titleFont": "Times New Roman"}
    },
    "color": {
      "field": "State",
      "type": "nominal",
      "scale": {"scheme": "category20b"},
      "legend": {"title": "Territory Matrix", "labelFont": "sans-serif", "titleFont": "Times New Roman"}
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "Year", "type": "quantitative"},
      {"field": "Dengue_Cases", "type": "quantitative", "title": "Cases Recorded", "format": ","},
      {"field": "Average_Temperature", "type": "quantitative", "title": "Temp (°C)"},
      {"field": "Average_Humidity", "type": "quantitative", "title": "Humidity (%)"}
    ]
  }
}