{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "background": "transparent",
  "data": {"url": "malaysia_dengue_weather_derived.csv"},
  "params": [
    {
      "name": "Year_Filter",
      "value": 2019,
      "bind": {"input": "select", "options": [2014, 2015, 2016, 2017, 2018, 2019], "name": "Observation Year: "}
    }
  ],
  "transform": [
    {"filter": "datum.Year == Year_Filter"}
  ],
  "mark": {"type": "bar", "color": "#1B5E9B", "cornerRadiusEnd": 2},
  "encoding": {
    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "axis": {"labelFont": "sans-serif", "title": null}
    },
    "x": {
      "field": "Dengue_Cases",
      "type": "quantitative",
      "axis": {"title": "Annual Case Volume", "labelFont": "sans-serif", "titleFont": "Times New Roman"}
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "Year", "type": "quantitative"},
      {"field": "Dengue_Cases", "type": "quantitative", "title": "Cases Registered", "format": ","}
    ]
  }
}