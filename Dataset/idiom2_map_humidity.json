{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "background": "transparent",
  "data": {
    "url": "malaysia-states.topojson",
    "format": {"type": "topojson", "feature": "states"}
  },
  "transform": [
    {
      "lookup": "properties.Name",
        "from": {
        "data": {"url": "malaysia_dengue_weather_derived.csv"},
        "key": "State",
        "fields": ["Average_Humidity"]
      }
    }
  ],
  "projection": {
    "type": "mercator"
  },
  "mark": {"type": "geoshape", "stroke": "rgba(255,255,255,0.1)", "strokeWidth": 0.8},
  "encoding": {
    "color": {
      "field": "Average_Humidity",
      "type": "quantitative",
      "title": "Humidity Baseline (%)",
      "scale": {"scheme": "tealblues", "domain": [78, 86]},
      "legend": {"labelFont": "sans-serif", "titleFont": "Times New Roman"}
    },
    "tooltip": [
      {"field": "properties.Name", "type": "nominal", "title": "State Territory"},
      {"field": "Average_Humidity", "type": "quantitative", "title": "Avg Humidity (%)", "format": ".2f"}
    ]
  }
}